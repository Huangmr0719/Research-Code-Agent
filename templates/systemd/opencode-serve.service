[Unit]
Description=OpenCode local server for Research-Code-Agent
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
# Replace /opt/baseline-project and env path before installing.
WorkingDirectory=/opt/baseline-project
EnvironmentFile=/etc/research-code-agent/feishu-bridge.env
ExecStart=/usr/bin/env opencode serve --hostname 127.0.0.1 --port 4096
Restart=always
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
